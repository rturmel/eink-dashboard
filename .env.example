# Copy to .env (docker compose loads this automatically) and fill in a
# real token before running `docker compose up`.
#
# Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
# This same token has to be given to every publisher (publisher_ha) and
# every client (pi_client) that talks to this broker.
DASHBOARD_TOKEN=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Host-side ports (only matter if 9090/9091 are already taken by something
# else on this machine -- e.g. running alongside other Compose projects).
# Whatever you set here is what pi_client/publisher_ha's broker_url and
# your browser need to use instead.
BROKER_PORT=9090
PREVIEW_PORT=9091

# python:3.12-slim defaults to UTC -- without this, the header's clock and
# "Data updated" timestamp will be off by however many hours you are from
# UTC. Use an IANA zone name (e.g. America/Montreal, America/New_York,
# Europe/Paris) -- see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Montreal
